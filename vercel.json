{
  "buildCommand": "npm run build",
  "outputDirectory": ".output/public",
  "framework": null,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/.output/server/index.mjs"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/.output/server/index.mjs"
    }
  ]
}
